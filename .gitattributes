# Canonical text bytes are part of task, schema, bundle, and workflow evidence.
# Keep them LF-normalized on every platform so a recorded SHA-256 identifies the
# same bytes on Windows, macOS, and Linux.
*.py      text eol=lf
*.pyi     text eol=lf
*.json    text eol=lf
*.jsonl   text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.toml    text eol=lf
*.md      text eol=lf
*.txt     text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.js      text eol=lf
*.sh      text eol=lf
*.xml     text eol=lf
*.log     text eol=lf
*.patch   text eol=lf
*.diff    text eol=lf
uv.lock   text eol=lf
Dockerfile text eol=lf
*.Dockerfile text eol=lf
LICENSE   text eol=lf
NOTICE    text eol=lf
PASS      text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Native Windows scripts retain Windows line endings when executed directly.
*.ps1     text eol=crlf
*.cmd     text eol=crlf
*.bat     text eol=crlf

# Never subject binary evidence to text conversion.
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.mp4     binary
*.wav     binary
*.zip     binary
*.zst     binary
*.gz      binary
*.pdf     binary
*.bin     binary
