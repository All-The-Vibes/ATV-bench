{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:atv-bench:schema:atv.trial-request:v1",
  "title": "ATV-Bench trial request v1",
  "type": "object",
  "required": [
    "schema",
    "protocol_version",
    "benchmark_release",
    "track",
    "run_id",
    "trial_id",
    "attempt_id",
    "schedule_id",
    "task_set",
    "issued_at",
    "expires_at",
    "nonce",
    "task",
    "harness",
    "model_policy",
    "workspace",
    "prompt",
    "budget_limits",
    "protocol_limits",
    "cancellation",
    "policy",
    "seed",
    "order_assignment",
    "output",
    "required_capabilities",
    "forbidden_capabilities"
  ],
  "properties": {
    "schema": {
      "const": "atv.trial-request/v1"
    },
    "protocol_version": {
      "const": 1
    },
    "benchmark_release": {
      "type": "string",
      "pattern": "^ATV-[0-9]{4}\\.[0-9]{2}(?:\\.[0-9]+)?$"
    },
    "track": {
      "type": "string",
      "enum": [
        "controlled",
        "systems",
        "resilience",
        "competitive"
      ]
    },
    "run_id": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/identifier"
    },
    "trial_id": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/identifier"
    },
    "attempt_id": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/identifier"
    },
    "schedule_id": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/identifier"
    },
    "task_set": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/versionedRef"
    },
    "issued_at": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/timestamp"
    },
    "expires_at": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/timestamp"
    },
    "nonce": {
      "type": "string",
      "minLength": 32,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "task": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/versionedRef"
    },
    "harness": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/versionedRef"
    },
    "model_policy": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/modelPolicy"
    },
    "workspace": {
      "type": "object",
      "required": [
        "path",
        "artifacts_path",
        "clean",
        "base_tree_digest"
      ],
      "properties": {
        "path": {
          "const": "/workspace"
        },
        "artifacts_path": {
          "const": "/artifacts"
        },
        "clean": {
          "const": true
        },
        "base_tree_digest": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/sha256"
        }
      },
      "unevaluatedProperties": false
    },
    "prompt": {
      "type": "object",
      "required": [
        "text",
        "encoding",
        "digest"
      ],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1048576
        },
        "encoding": {
          "const": "utf-8"
        },
        "digest": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/sha256"
        }
      },
      "unevaluatedProperties": false
    },
    "budget_limits": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/budgetLimits"
    },
    "protocol_limits": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/protocolLimits"
    },
    "cancellation": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/cancellationPolicy"
    },
    "policy": {
      "type": "object",
      "required": [
        "tools",
        "network",
        "writable_paths",
        "credentials"
      ],
      "properties": {
        "tools": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/toolPolicy"
        },
        "network": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/networkPolicy"
        },
        "writable_paths": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/absoluteGuestPath"
          }
        },
        "credentials": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/credentialHandle"
          }
        }
      },
      "unevaluatedProperties": false
    },
    "seed": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/safeUnsignedInteger"
    },
    "order_assignment": {
      "type": "object",
      "required": [
        "block",
        "repetition",
        "position",
        "side",
        "worker_class"
      ],
      "properties": {
        "block": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/safeUnsignedInteger"
        },
        "repetition": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/safeUnsignedInteger"
        },
        "position": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/safeUnsignedInteger"
        },
        "side": {
          "type": "string",
          "enum": [
            "a",
            "b",
            "none"
          ]
        },
        "worker_class": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/identifier"
        }
      },
      "unevaluatedProperties": false
    },
    "output": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/artifactContract"
    },
    "required_capabilities": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/capabilities"
    },
    "forbidden_capabilities": {
      "type": "array",
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "subagents",
          "resumable",
          "browser",
          "model_events",
          "tool_events",
          "usage_events",
          "checkpoint_events"
        ]
      }
    }
  },
  "unevaluatedProperties": false
}
