{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:atv-bench:schema:atv.task:v1",
  "title": "ATV-Bench task manifest v1",
  "$defs": {
    "independentReviewDescriptor": {
      "description": "Task packages require atv.independent-review/v2. The legacy atv.task-review/v1 token remains schema-readable for protocol-v1 document compatibility but is rejected by the task-package credibility validator.",
      "type": "object",
      "required": [
        "schema",
        "path",
        "media_type",
        "size_bytes",
        "digest"
      ],
      "properties": {
        "schema": {
          "type": "string",
          "enum": [
            "atv.independent-review/v2",
            "atv.task-review/v1"
          ]
        },
        "path": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/relativePath"
        },
        "media_type": {
          "const": "application/json"
        },
        "size_bytes": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/safePositiveInteger"
        },
        "digest": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/sha256"
        }
      },
      "unevaluatedProperties": false
    }
  },
  "type": "object",
  "required": [
    "schema",
    "id",
    "version",
    "title",
    "category",
    "capability_tags",
    "track_compatibility",
    "difficulty",
    "visibility",
    "source",
    "environment",
    "prompt",
    "policy",
    "budget_limits",
    "output",
    "grader",
    "validation_evidence",
    "protocol_range",
    "license"
  ],
  "properties": {
    "schema": {
      "const": "atv.task/v1"
    },
    "id": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/identifier"
    },
    "version": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/semanticVersion"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "category": {
      "type": "string",
      "enum": [
        "greenfield",
        "repair",
        "debugging",
        "long-horizon",
        "recovery",
        "tool-use",
        "context-retrieval",
        "competitive"
      ]
    },
    "capability_tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/identifier"
      }
    },
    "track_compatibility": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "controlled",
          "systems",
          "resilience",
          "competitive"
        ]
      }
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "smoke",
        "easy",
        "medium",
        "hard",
        "expert"
      ]
    },
    "visibility": {
      "type": "string",
      "enum": [
        "public",
        "private",
        "rotating"
      ]
    },
    "source": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/sourceRevision"
    },
    "environment": {
      "type": "object",
      "required": [
        "image",
        "platform"
      ],
      "properties": {
        "image": {
          "type": "string",
          "minLength": 73,
          "maxLength": 2048,
          "pattern": "^[^\\s@]+@sha256:[0-9a-f]{64}$"
        },
        "platform": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/platform"
        }
      },
      "unevaluatedProperties": false
    },
    "prompt": {
      "type": "object",
      "required": [
        "path",
        "encoding",
        "media_type",
        "digest"
      ],
      "properties": {
        "path": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/relativePath"
        },
        "encoding": {
          "const": "utf-8"
        },
        "media_type": {
          "const": "text/markdown"
        },
        "digest": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/sha256"
        }
      },
      "unevaluatedProperties": false
    },
    "policy": {
      "type": "object",
      "required": [
        "tools",
        "network",
        "writable_paths",
        "credential_names"
      ],
      "properties": {
        "tools": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/toolPolicy"
        },
        "network": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/networkPolicy"
        },
        "writable_paths": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/absoluteGuestPath"
          }
        },
        "credential_names": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/environmentName"
          }
        }
      },
      "unevaluatedProperties": false
    },
    "budget_limits": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/budgetLimits"
    },
    "output": {
      "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/artifactContract"
    },
    "grader": {
      "type": "object",
      "required": [
        "image",
        "command",
        "network",
        "budget_limits",
        "hidden_inputs_digest",
        "result_schema_digest",
        "score_scale",
        "replay_runs"
      ],
      "properties": {
        "image": {
          "type": "string",
          "minLength": 73,
          "maxLength": 2048,
          "pattern": "^[^\\s@]+@sha256:[0-9a-f]{64}$"
        },
        "command": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096
          }
        },
        "network": {
          "type": "object",
          "required": [
            "mode",
            "allowed_destinations"
          ],
          "properties": {
            "mode": {
              "const": "none"
            },
            "allowed_destinations": {
              "type": "array",
              "maxItems": 0
            }
          },
          "unevaluatedProperties": false
        },
        "budget_limits": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/budgetLimits"
        },
        "hidden_inputs_digest": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/sha256"
        },
        "result_schema_digest": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/sha256"
        },
        "score_scale": {
          "type": "object",
          "required": [
            "possible",
            "unit"
          ],
          "properties": {
            "possible": {
              "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/safePositiveInteger"
            },
            "unit": {
              "const": "points"
            }
          },
          "unevaluatedProperties": false
        },
        "replay_runs": {
          "type": "integer",
          "minimum": 2,
          "maximum": 100
        }
      },
      "unevaluatedProperties": false
    },
    "validation_evidence": {
      "type": "object",
      "required": [
        "oracle",
        "noop",
        "alternative_solutions",
        "exploit_cases",
        "mutation_cases",
        "independent_review"
      ],
      "properties": {
        "oracle": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/documentDescriptor"
        },
        "noop": {
          "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/documentDescriptor"
        },
        "alternative_solutions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1000,
          "items": {
            "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/documentDescriptor"
          }
        },
        "exploit_cases": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1000,
          "items": {
            "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/documentDescriptor"
          }
        },
        "mutation_cases": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1000,
          "items": {
            "$ref": "urn:atv-bench:schema:atv.common:v1#/$defs/documentDescriptor"
          }
        },
        "independent_review": {
          "$ref": "#/$defs/independentReviewDescriptor"
        }
      },
      "unevaluatedProperties": false
    },
    "protocol_range": {
      "type": "object",
      "required": [
        "minimum",
        "maximum"
      ],
      "properties": {
        "minimum": {
          "const": 1
        },
        "maximum": {
          "const": 1
        }
      },
      "unevaluatedProperties": false
    },
    "license": {
      "type": "object",
      "required": [
        "spdx",
        "redistribution"
      ],
      "properties": {
        "spdx": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "redistribution": {
          "type": "string",
          "enum": [
            "allowed",
            "restricted",
            "prohibited"
          ]
        }
      },
      "unevaluatedProperties": false
    }
  },
  "unevaluatedProperties": false
}
